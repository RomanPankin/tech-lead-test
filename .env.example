# --- Anti-spam (Cloudflare Turnstile) ---
# Server-side secret used to verify the Turnstile token. When unset, the demo
# handler skips remote verification but still enforces the honeypot + rate limit.
TURNSTILE_SECRET_KEY=

# Public site key, exposed to the browser widget.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Lead storage (demo) ---
# Where the demo file-store writes captured leads (JSON Lines).
LEAD_STORE_PATH=./data/leads.jsonl

# --- Delivery routing (placeholders for real integrations) ---
# Transactional email provider key (e.g. Postmark / SES) for email-type leads.
EMAIL_PROVIDER_API_KEY=
# Base URL + key for the 3rd-party CRM/API that some lead types route to.
CRM_API_BASE_URL=
CRM_API_KEY=
